{
  "name": "reqex",
  "version": "0.1.0",
  "description": "Terminal HTTP client powered by httpyac and Rezi",
  "type": "module",
  "bin": {
    "reqex": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsup",
    "start": "node dist/cli.js",
    "test": "tsx --test test/**/*.test.ts",
    "check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/churivibhav/reqex.git"
  },
  "keywords": ["http", "rest", "tui", "httpyac", "terminal"],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/churivibhav/reqex/issues"
  },
  "homepage": "https://github.com/churivibhav/reqex#readme",
  "dependencies": {
    "@rezi-ui/core": "0.1.0-beta.2",
    "@rezi-ui/node": "0.1.0-beta.2",
    "chokidar": "^5.0.0",
    "clipboardy": "^5.3.1",
    "httpyac": "6.16.7"
  },
  "devDependencies": {
    "@rezi-ui/testkit": "0.1.0-beta.2",
    "@types/node": "^22.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
